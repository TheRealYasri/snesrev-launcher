export SMB1_ROM=$(find_and_rename_rom "$HASH_SMB1" "smb1.sfc")
export SMBLL_ROM=$(find_and_rename_rom "$HASH_SMBLL" "smbll.sfc")

export Z3_DE_ROM=$(find_and_rename_rom "$HASH_Z3_DE" "zelda3.de.sfc")
export Z3_FR_ROM=$(find_and_rename_rom "$HASH_Z3_FR" "zelda3.fr.sfc")
export Z3_FRC_ROM=$(find_and_rename_rom "$HASH_Z3_FRC" "zelda3.fr-c.sfc")
export Z3_ES_ROM=$(find_and_rename_rom "$HASH_Z3_ES" "zelda3.es.sfc")
export Z3_PL_ROM=$(find_and_rename_rom "$HASH_Z3_PL" "zelda3.pl.sfc")
export Z3_PT_ROM=$(find_and_rename_rom "$HASH_Z3_PT" "zelda3.pt.sfc")
export Z3_NL_ROM=$(find_and_rename_rom "$HASH_Z3_NL" "zelda3.nl.sfc")
export Z3_SV_ROM=$(find_and_rename_rom "$HASH_Z3_SV" "zelda3.sv.sfc")
export Z3_REDUX_ROM=$(find_and_rename_rom "$HASH_Z3_REDUX" "zelda3.redux.sfc")

extract_language () {
    echo ">> Processing dialogue for language: $1"
    sed -i 's/# Language/Language/g' ../zelda3.ini
    sed -i "s/Language = .*/Language = $1/g" ../zelda3.ini
    "${SCRIPT_PATH}"/bin/python3 restool.py --extract-dialogue -r translate.sfc
    "${SCRIPT_PATH}"/bin/python3 restool.py --languages="$1"
}

link_rom() {
    [ -n "$1" ] && [ -e "$1" ] && ln -sf "$1" "$(basename "$1")"
}

extractrom () {
    export LD_LIBRARY_PATH="${SCRIPT_PATH}/lib:${LD_LIBRARY_PATH}"

    for f in zelda3.ini sm.ini smw.ini zelda3_assets.dat saves \
             zelda3.sfc sm.smc smw.sfc smb1.sfc smbll.sfc \
             zelda3.*.sfc; do
        if [ -L "$f" ]; then rm "$f"; fi
    done

    local TYPE=$1; shift
    
    local CONF_DIR="srl-config/$TYPE"
    local SAVE_DIR="srl-saves/$TYPE"
    mkdir -p "$CONF_DIR" "$SAVE_DIR"
    
    if [ -d "saves" ] && [ ! -L "saves" ]; then mv "saves" "saves.bak"; fi
    # Force creation of the link (cleanup loop above handles removal if it was a link)
    ln -sf "$SAVE_DIR" "saves"
    
    echo ">> Preparing to launch: $TYPE (Config: $CONF_DIR | Saves: $SAVE_DIR)"

    case "$TYPE" in
        z3|z3-*)
            local TARGET_LANG=""
            local TRANS_ROM_VAR=""
            case "$TYPE" in
                z3|z3-en) TARGET_LANG="en";;
                z3-de)    TARGET_LANG="de";    TRANS_ROM_VAR="$Z3_DE_ROM";;
                z3-fr)    TARGET_LANG="fr";    TRANS_ROM_VAR="$Z3_FR_ROM";;
                z3-fr-c)  TARGET_LANG="fr-c";  TRANS_ROM_VAR="$Z3_FRC_ROM";;
                z3-es)    TARGET_LANG="es";    TRANS_ROM_VAR="$Z3_ES_ROM";;
                z3-pl)    TARGET_LANG="pl";    TRANS_ROM_VAR="$Z3_PL_ROM";;
                z3-pt)    TARGET_LANG="pt";    TRANS_ROM_VAR="$Z3_PT_ROM";;
                z3-nl)    TARGET_LANG="nl";    TRANS_ROM_VAR="$Z3_NL_ROM";;
                z3-sv)    TARGET_LANG="sv";    TRANS_ROM_VAR="$Z3_SV_ROM";;
                z3-redux) TARGET_LANG="redux"; TRANS_ROM_VAR="$Z3_REDUX_ROM";;
            esac

            local LANG_DAT="$CONF_DIR/zelda3_assets.dat"

            if [ ! -e "$LANG_DAT" ]; then
                echo ">> Asset file '$LANG_DAT' not found. Starting extraction..."
                [ -z "$Z3_ROM" ] && { echo "Error: Missing US Zelda 3 ROM content."; exit 1; }
                if [ "$TARGET_LANG" != "en" ] && [ -z "$TRANS_ROM_VAR" ]; then
                    echo "Error: Missing translation ROM content for $TARGET_LANG."; exit 1
                fi

                export ASSETDIR="$(mktemp -d /tmp/z3-XXXXX)"
                echo ">> Created temp directory: $ASSETDIR"
                cp -r "${SCRIPT_PATH}"/assets/* "$ASSETDIR"
                cp "$Z3_ROM" "$ASSETDIR/tables/zelda3.sfc"
                [ -n "$TRANS_ROM_VAR" ] && cp "$TRANS_ROM_VAR" "$ASSETDIR/tables/translate.sfc"
                
                cd "$ASSETDIR"/tables
                echo ">> Running python extractor on main ROM..."
                "${SCRIPT_PATH}"/bin/python3 restool.py --extract-from-rom -r zelda3.sfc
                [ -e "translate.sfc" ] && [ "$TARGET_LANG" != "en" ] && extract_language "$TARGET_LANG"
                cd - > /dev/null
                
                echo ">> Moving generated assets to '$CONF_DIR'..."
                cp "$ASSETDIR"/tables/zelda3_assets.dat "$LANG_DAT"
                
                [ -e "$ASSETDIR"/zelda3.ini ] && [ ! -e "$CONF_DIR/zelda3.ini" ] && cp "$ASSETDIR"/zelda3.ini "$CONF_DIR/zelda3.ini"
                rm -rf "$ASSETDIR"
                echo ">> Cleanup complete."
            fi

            ln -sf "$LANG_DAT" zelda3_assets.dat
            link_rom "$Z3_ROM"
            [ -n "$TRANS_ROM_VAR" ] && link_rom "$TRANS_ROM_VAR"
            
            local REAL_CONF="$CONF_DIR/zelda3.ini"
            if [ ! -e "$REAL_CONF" ]; then
                echo ">> Initializing new configuration..."
                [ -e "zelda3.ini.$TARGET_LANG" ] && cp "zelda3.ini.$TARGET_LANG" "$REAL_CONF" || cp "${SCRIPT_PATH}"/assets/zelda3.ini "$REAL_CONF"
            fi
            
            echo ">> Linking configuration..."
            ln -sf "$REAL_CONF" zelda3.ini
            
            echo ">> Launching Zelda 3 executable..."
            "${SCRIPT_PATH}"/bin/zelda3 "$@"

            if [ ! -L "zelda3.ini" ] && [ -f "zelda3.ini" ]; then
                echo ">> Syncing configuration change back to storage..."
                mv "zelda3.ini" "$REAL_CONF"
            fi
            ;;
        sm)
            [ -z "$SM_ROM" ] && { echo "Error: Super Metroid ROM not found."; exit 1; }
            link_rom "$SM_ROM"
            
            local REAL_CONF="$CONF_DIR/sm.ini"
            [ ! -e "$REAL_CONF" ] && cp "${SCRIPT_PATH}"/assets/sm.ini "$REAL_CONF"
            
            echo ">> Linking configuration..."
            ln -sf "$REAL_CONF" sm.ini

            echo ">> Launching Super Metroid executable..."
            "${SCRIPT_PATH}"/bin/sm "$@"

            if [ ! -L "sm.ini" ] && [ -f "sm.ini" ]; then
                echo ">> Syncing configuration change back to storage..."
                mv "sm.ini" "$REAL_CONF"
            fi
            ;;
        smw)
            [ -z "$SMW_ROM" ] && { echo "Error: Super Mario World ROM not found."; exit 1; }
            link_rom "$SMW_ROM"
            
            local REAL_CONF="$CONF_DIR/smw.ini"
            [ ! -e "$REAL_CONF" ] && cp "${SCRIPT_PATH}"/assets/smw.ini "$REAL_CONF"
            
            echo ">> Linking configuration..."
            ln -sf "$REAL_CONF" smw.ini

            echo ">> Launching Super Mario World executable..."
            "${SCRIPT_PATH}"/bin/smw "$@"

            if [ ! -L "smw.ini" ] && [ -f "smw.ini" ]; then
                echo ">> Syncing configuration change back to storage..."
                mv "smw.ini" "$REAL_CONF"
            fi
            ;;
        smb1|smbll)
            local TARGET_ROM=""
            local CONF_ROM_PATH="srl-roms/$TYPE.sfc"
            
            if [ -e "$CONF_ROM_PATH" ]; then TARGET_ROM="$CONF_ROM_PATH"; fi

            if [ -z "$TARGET_ROM" ]; then
                echo ">> Target ROM '$TYPE.sfc' missing. Extracting from All-Stars..."
                [ -z "$SMAS_ROM" ] && { echo "Error: All-Stars ROM not found."; exit 1; }
                export ASSETDIR="$(mktemp -d /tmp/smb-XXXXX)"
                cp -r "${SCRIPT_PATH}"/assets/smb "$ASSETDIR"
                cp "$SMAS_ROM" "$ASSETDIR/smas.sfc"
                cd "$ASSETDIR"/smb && "${SCRIPT_PATH}"/bin/python3 extract.py && cd - > /dev/null
                echo ">> Extraction done. Moving ROMs to srl-roms/..."
                mv "$ASSETDIR/smb/smb1.sfc" "srl-roms/"
                mv "$ASSETDIR/smb/smbll.sfc" "srl-roms/"
                rm -rf "$ASSETDIR"
                TARGET_ROM="$CONF_ROM_PATH"
            fi
            
            link_rom "$TARGET_ROM"
            local REAL_CONF="$CONF_DIR/smw.ini"
            [ ! -e "$REAL_CONF" ] && cp "${SCRIPT_PATH}"/assets/smw.ini "$REAL_CONF"
            
            echo ">> Linking configuration..."
            ln -sf "$REAL_CONF" smw.ini

            echo ">> Launching SMW (SMB Mode)..."
            "${SCRIPT_PATH}"/bin/smw "$(basename "$TARGET_ROM")" "$@"

            if [ ! -L "smw.ini" ] && [ -f "smw.ini" ]; then
                echo ">> Syncing configuration change back to storage..."
                mv "smw.ini" "$REAL_CONF"
            fi
            ;;
    esac
}

COMMAND=$1; shift
case "$COMMAND" in
    z3|z3-*|sm|smw|smb1|smbll) extractrom "$COMMAND" "$@" ;;
    *) echo "Error: '$COMMAND' invalid."; echo ""; show_help; exit 1 ;;
esac

