install_desktop_file() {
    local KEY="$1"
    local TITLE="$2"
    local USER_APP_DIR="$HOME/.local/share/applications"
    
    local ICON_NAME="utilities-terminal"
    case "$KEY" in
        z3*) ICON_NAME="z3.png" ;;
        sm)  ICON_NAME="sm.png" ;;
        smw|smb*) ICON_NAME="smw.png" ;;
    esac
    
    local ICON_PATH="utilities-terminal"
    if [ -f "$INSTALL_DIR/srl-config/icons/$ICON_NAME" ]; then
        ICON_PATH="$INSTALL_DIR/srl-config/icons/$ICON_NAME"
    fi

    local FILE="$USER_APP_DIR/SRL-$TITLE.desktop"
    
    if [ -f "$FILE" ]; then
        rm "$FILE"
        sleep .5
    fi
    
    if [ "$GUI_MODE" -eq 0 ]; then
        echo ">> Writing Shortcut: $TITLE" >&2
    fi
    
    cat > "$FILE" <<EOF
[Desktop Entry]
Type=Application
Name=SRL-$TITLE
Exec="$INSTALL_DIR/$LAUNCHER_EXEC" $KEY
Path=$INSTALL_DIR
Icon=$ICON_PATH
Terminal=false
Categories=Game;
StartupNotify=false
EOF
    chmod +x "$FILE"
    
    sleep .5
}

sync_desktop_shortcuts() {
    local USER_APP_DIR="$HOME/.local/share/applications"
    mkdir -p "$USER_APP_DIR"

    for entry in "${GAME_LIST[@]}"; do
        local KEY="${entry%%|*}"
        local TITLE="${entry#*|}"
        local FILE="$USER_APP_DIR/SRL-$TITLE.desktop"
        
        if [ "${IS_PLAYABLE[$KEY]}" -eq 1 ]; then
            if [ "$REFRESH_DESKTOP" == "1" ] || [ ! -f "$FILE" ]; then
                install_desktop_file "$KEY" "$TITLE"
            fi
        else
            if [ -f "$FILE" ]; then
                if [ "$GUI_MODE" -eq 0 ]; then
                    echo ">> Removing obsolete: $TITLE" >&2
                fi
                rm "$FILE"
                sleep .5
            fi
        fi
    done

    if [ "$REFRESH_DESKTOP" == "1" ]; then
        if [ "$GUI_MODE" -eq 0 ]; then
            echo ">> Desktop refresh complete. Resetting flag." >&2
        fi
        write_config "REFRESH_DESKTOP" "0"
    fi
}

remove_all_desktops() {
    local TARGET_DIR="$HOME/.local/share/applications"
    for f in "$TARGET_DIR/SRL-"*".desktop"; do
        if [ -e "$f" ]; then
            rm "$f"
            sleep .5
        fi
    done
    
    if [ "$GUI_MODE" -eq 0 ]; then
        echo ">> All desktop shortcuts removed." >&2
    fi
}

toggle_desktop_install() {
    if [ "$INSTALL_DESKTOP" -eq 1 ]; then
        INSTALL_DESKTOP=0
        STATE_TXT="Disabled"
        remove_all_desktops
    else
        INSTALL_DESKTOP=1
        STATE_TXT="Enabled"
        REFRESH_DESKTOP=1
        sync_desktop_shortcuts
    fi
    
    write_config "INSTALL_DESKTOP" "$INSTALL_DESKTOP"
    
    if [ "$GUI_MODE" -eq 1 ] && command -v zenity &>/dev/null; then
        zenity --info --text="Desktop Integration: $STATE_TXT" --timeout=2
        exec "$INSTALL_DIR/$LAUNCHER_EXEC"
    else
        echo ">> Desktop Integration: $STATE_TXT"
    fi
}

if [ "$INSTALL_DESKTOP" -eq 1 ]; then
    sync_desktop_shortcuts
fi

if [ "$GUI_MODE" -eq 1 ]; then 
    if command -v zenity &>/dev/null; then
        ZEN_ARGS=()
        for entry in "${GAME_LIST[@]}"; do
            KEY="${entry%%|*}"
            TITLE="${entry#*|}"
            if [ "${IS_PLAYABLE[$KEY]}" -eq 1 ]; then
                ZEN_ARGS+=("$KEY" "$TITLE")
            else
                ZEN_ARGS+=("$KEY" "$TITLE (Missing Files)")
            fi
        done

        if [ "$INSTALL_DESKTOP" -eq 1 ]; then
            DESK_LBL="Desktop Shortcuts (Enabled)"
        else
            DESK_LBL="Desktop Shortcuts (Disabled)"
        fi
        ZEN_ARGS+=("desktop" ">> $DESK_LBL <<")

        SEL=$(zenity --list --title="SNESREV Launcher" --height=600 --width=450 \
            --column="Cmd" --column="Game" --hide-header "${ZEN_ARGS[@]}")
        
        [ -z "$SEL" ] && exit 0
        set -- "$SEL"
    else
        show_help; exit 0
    fi
fi

extract_language () {
    echo ">> Processing dialogue for language: $1"
    sed -i 's/# Language/Language/g' ../zelda3.ini
    sed -i "s/Language = .*/Language = $1/g" ../zelda3.ini
    "${SCRIPT_PATH}"/bin/python3 restool.py --extract-dialogue -r translate.sfc
    "${SCRIPT_PATH}"/bin/python3 restool.py --languages="$1"
}

link_rom() {
    [ -n "$1" ] && [ -e "$1" ] && ln -sf "$1" "$(basename "$1")"
}

launch_std() {
    local ROM_VAR="$1"
    local BIN_NAME="$2"
    local INI_NAME="$3"
    local ARG_4="$4"
    shift 4

    [ -z "$ROM_VAR" ] && { echo "Error: ROM for $BIN_NAME not found."; exit 1; }
    link_rom "$ROM_VAR"

    local REAL_CONF="$CONF_DIR/$TYPE/$INI_NAME"
    if [ ! -e "$REAL_CONF" ]; then
        cp "${SCRIPT_PATH}/assets/$INI_NAME" "$REAL_CONF"
    fi
    link_rom "$REAL_CONF" "$INI_NAME"

    echo ">> Launching $BIN_NAME..."
    if [ -n "$ARG_4" ]; then
        "${SCRIPT_PATH}/bin/$BIN_NAME" "$ARG_4" "$@"
    else
        "${SCRIPT_PATH}/bin/$BIN_NAME" "$@"
    fi

    if [ ! -L "$INI_NAME" ] && [ -f "$INI_NAME" ]; then
        echo ">> Syncing configuration..."
        mv "$INI_NAME" "$REAL_CONF"
    fi
}

launch_z3() {
    local TYPE="$1"
    shift
    local TARGET_LANG=""
    local TRANS_ROM_VAR=""
    
    case "$TYPE" in
        z3|z3-en) TARGET_LANG="en";;
        z3-de)    TARGET_LANG="de";    TRANS_ROM_VAR="$Z3_DE_ROM";;
        z3-fr)    TARGET_LANG="fr";    TRANS_ROM_VAR="$Z3_FR_ROM";;
        z3-fr-c)  TARGET_LANG="fr-c";  TRANS_ROM_VAR="$Z3_FRC_ROM";;
        z3-es)    TARGET_LANG="es";    TRANS_ROM_VAR="$Z3_ES_ROM";;
        z3-pl)    TARGET_LANG="pl";    TRANS_ROM_VAR="$Z3_PL_ROM";;
        z3-pt)    TARGET_LANG="pt";    TRANS_ROM_VAR="$Z3_PT_ROM";;
        z3-nl)    TARGET_LANG="nl";    TRANS_ROM_VAR="$Z3_NL_ROM";;
        z3-sv)    TARGET_LANG="sv";    TRANS_ROM_VAR="$Z3_SV_ROM";;
        z3-redux) TARGET_LANG="redux"; TRANS_ROM_VAR="$Z3_REDUX_ROM";;
    esac

    local LANG_DAT="$CONF_DIR/$TYPE/zelda3_assets.dat"

    if [ ! -e "$LANG_DAT" ]; then
        echo ">> Asset file '$LANG_DAT' not found. Starting extraction..."
        [ -z "$Z3_ROM" ] && { echo "Error: Missing US Zelda 3 ROM content."; exit 1; }
        if [ "$TARGET_LANG" != "en" ] && [ -z "$TRANS_ROM_VAR" ]; then
            echo "Error: Missing translation ROM content for $TARGET_LANG."; exit 1
        fi

        export ASSETDIR="$(mktemp -d /tmp/z3-XXXXX)"
        cp -r "${SCRIPT_PATH}"/assets/* "$ASSETDIR"
        cp "$Z3_ROM" "$ASSETDIR/tables/zelda3.sfc"
        [ -n "$TRANS_ROM_VAR" ] && cp "$TRANS_ROM_VAR" "$ASSETDIR/tables/translate.sfc"
        
        cd "$ASSETDIR"/tables
        "${SCRIPT_PATH}"/bin/python3 restool.py --extract-from-rom -r zelda3.sfc
        [ -e "translate.sfc" ] && [ "$TARGET_LANG" != "en" ] && extract_language "$TARGET_LANG"
        cd - > /dev/null
        
        cp "$ASSETDIR"/tables/zelda3_assets.dat "$LANG_DAT"
        [ -e "$ASSETDIR"/zelda3.ini ] && [ ! -e "$CONF_DIR/$TYPE/zelda3.ini" ] && cp "$ASSETDIR"/zelda3.ini "$CONF_DIR/$TYPE/zelda3.ini"
        rm -rf "$ASSETDIR"
    fi

    ln -sf "$LANG_DAT" zelda3_assets.dat
    link_rom "$Z3_ROM"
    [ -n "$TRANS_ROM_VAR" ] && link_rom "$TRANS_ROM_VAR"
    
    local REAL_CONF="$CONF_DIR/$TYPE/zelda3.ini"
    if [ ! -e "$REAL_CONF" ]; then
         [ -e "zelda3.ini.$TARGET_LANG" ] && cp "zelda3.ini.$TARGET_LANG" "$REAL_CONF" || cp "${SCRIPT_PATH}"/assets/zelda3.ini "$REAL_CONF"
    fi
    link_rom "$REAL_CONF" zelda3.ini
    
    echo ">> Launching Zelda 3 executable..."
    "${SCRIPT_PATH}"/bin/zelda3 "$@"

    if [ ! -L "zelda3.ini" ] && [ -f "zelda3.ini" ]; then
        mv "zelda3.ini" "$REAL_CONF"
    fi
}

extractrom () {
    export LD_LIBRARY_PATH="${SCRIPT_PATH}/lib:${LD_LIBRARY_PATH}"

    for f in zelda3.ini sm.ini smw.ini zelda3_assets.dat saves \
             zelda3.sfc sm.smc smw.sfc smb1.sfc smbll.sfc \
             zelda3.*.sfc; do
        if [ -L "$f" ]; then rm "$f"; fi
    done

    local TYPE=$1; shift
    local CONF_DIR="srl-config" 
    local SAVE_DIR="srl-saves/$TYPE"
    mkdir -p "$CONF_DIR/$TYPE" "$SAVE_DIR"
    
    if [ "${IS_PLAYABLE[$TYPE]}" -eq 0 ]; then
        echo "Error: Missing required ROM files for $TYPE." >&2
        exit 1
    fi

    if [ -d "saves" ] && [ ! -L "saves" ]; then mv "saves" "saves.bak"; fi
    ln -sf "$SAVE_DIR" "saves"
    
    echo ">> Preparing to launch: $TYPE (Config: $CONF_DIR/$TYPE | Saves: $SAVE_DIR)"

    case "$TYPE" in
        z3|z3-*)
            launch_z3 "$TYPE" "$@"
            ;;
        sm)
            launch_std "$SM_ROM" "sm" "sm.ini" "" "$@" 
            ;;
        smw)
            launch_std "$SMW_ROM" "smw" "smw.ini" "" "$@"
            ;;
        smb1|smbll)
            local TARGET_ROM=""
            local CONF_ROM_PATH="srl-roms/$TYPE.sfc"
            [ -e "$CONF_ROM_PATH" ] && TARGET_ROM="$CONF_ROM_PATH"

            if [ -z "$TARGET_ROM" ]; then
                echo ">> Extracting from All-Stars..."
                [ -z "$SMAS_ROM" ] && { echo "Error: All-Stars ROM not found."; exit 1; }
                export ASSETDIR="$(mktemp -d /tmp/smb-XXXXX)"
                cp -r "${SCRIPT_PATH}"/assets/smb "$ASSETDIR"
                cp "$SMAS_ROM" "$ASSETDIR/smas.sfc"
                cd "$ASSETDIR"/smb && "${SCRIPT_PATH}"/bin/python3 extract.py && cd - > /dev/null
                mv "$ASSETDIR/smb/smb1.sfc" "srl-roms/"
                mv "$ASSETDIR/smb/smbll.sfc" "srl-roms/"
                rm -rf "$ASSETDIR"
                TARGET_ROM="$CONF_ROM_PATH"
            fi
            
            launch_std "$TARGET_ROM" "smw" "smw.ini" "$(basename "$TARGET_ROM")" "$@"
            ;;
    esac
}

COMMAND=$1; shift
case "$COMMAND" in
    desktop) toggle_desktop_install ;;
    z3|z3-*|sm|smw|smb1|smbll) extractrom "$COMMAND" "$@" ;;
    *) echo "Error: '$COMMAND' invalid."; echo ""; show_help; exit 1 ;;
esac


