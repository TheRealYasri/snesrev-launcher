#!/bin/bash

INTERNAL_DIR="$(dirname "$(realpath "$0")")"
SCRIPT_PATH="${INTERNAL_DIR}/usr"

if [ -n "$APPIMAGE" ]; then
    INSTALL_DIR="$(dirname "$(realpath "$APPIMAGE")")"
    LAUNCHER_EXEC=$(basename "$APPIMAGE")
else
    INSTALL_DIR="$(dirname "$(realpath "$0")")"
    LAUNCHER_EXEC=$(basename "$0")
fi

cd "$INSTALL_DIR" || exit 1

mkdir -p "srl-roms" "srl-config" "srl-saves" "srl-config/icons"

CONF_DIR="srl-config"
CONF_FILE="srl-config/srl.ini"

GUI_MODE=0
if [ $# -eq 0 ]; then
    GUI_MODE=1
fi

if [ -f "$CONF_FILE" ]; then
    source "$CONF_FILE"
fi

write_config() {
    local KEY="$1"
    local VAL="$2"
    
    touch "$CONF_FILE"
    
    sed -i "/^$KEY=/d" "$CONF_FILE"
    
    echo "$KEY=\"$VAL\"" >> "$CONF_FILE"
}

# --- Default to OFF (0) ---
[ -z "$INSTALL_DESKTOP" ] && INSTALL_DESKTOP=0

if [ "$INSTALL_DIR" != "$LAST_PATH" ]; then
    echo ">> Detected path change ($LAST_PATH -> $INSTALL_DIR)" >&2
    echo ">> Updating configuration..." >&2
    
    write_config "LAST_PATH" "$INSTALL_DIR"
    write_config "REFRESH_DESKTOP" "1"
    
    LAST_PATH="$INSTALL_DIR"
    REFRESH_DESKTOP=1
fi

update_rom_cache() {
    local KEY="$1"
    local FILE="$2"
    local TS="$3"
    write_config "CACHE_${KEY}_PATH" "$FILE"
    write_config "CACHE_${KEY}_TIME" "$TS"
}

sync_app_icon() {
    local NAME="$1"
    local SRC="$INTERNAL_DIR/$NAME"
    local DST="$INSTALL_DIR/srl-config/icons/$NAME"
    
    local CLEAN_NAME="${NAME//./_}"
    local CACHE_VAR="CACHE_ICON_${CLEAN_NAME}_TIME"
    local SAVED_TIME="${!CACHE_VAR}"

    if [ -f "$SRC" ]; then
        local CURR_TIME=$(stat -c %Y "$SRC")
        
        if [ "$CURR_TIME" == "$SAVED_TIME" ] && [ -f "$DST" ]; then
            return
        fi
        
        echo ">> Updating Icon: $NAME" >&2
        cp "$SRC" "$DST"
        write_config "$CACHE_VAR" "$CURR_TIME"
    elif [ -f "$DST" ]; then
        return
    fi
}

