find_and_rename_rom() {
    local TARGET_HASH="$1"
    local NEW_NAME="$2"
    local ROM_DIR="srl-roms"
    local HASHER=""

    if command -v sha1sum &> /dev/null; then HASHER="sha1sum"
    elif command -v shasum &> /dev/null; then HASHER="shasum"
    else echo "Error: No hashing tool found." >&2; exit 1; fi

    if [ -e "$ROM_DIR/$NEW_NAME" ]; then
        echo "$ROM_DIR/$NEW_NAME"
        return
    fi

    # 2. Check root directory (Move if found)
    local FOUND_FILE=$($HASHER *.s[mf]c *.smc 2>/dev/null | grep -iE "$TARGET_HASH" | head -n 1 | sed 's/^[0-9a-fA-F]*  //')
    if [ -n "$FOUND_FILE" ]; then
        echo ">> ROM Found! Moving '$FOUND_FILE' -> '$ROM_DIR/$NEW_NAME'" >&2
        mv "$FOUND_FILE" "$ROM_DIR/$NEW_NAME"
        echo "$ROM_DIR/$NEW_NAME"
        return
    fi

    FOUND_FILE=$($HASHER "$ROM_DIR"/*.s[mf]c "$ROM_DIR"/*.smc 2>/dev/null | grep -iE "$TARGET_HASH" | head -n 1 | sed 's/^[0-9a-fA-F]*  //')
    if [ -n "$FOUND_FILE" ]; then
        echo ">> ROM Found in $ROM_DIR! Renaming '$FOUND_FILE' -> '$ROM_DIR/$NEW_NAME'" >&2
        mv "$FOUND_FILE" "$ROM_DIR/$NEW_NAME"
        echo "$ROM_DIR/$NEW_NAME"
        return
    fi
}

echo ">> Scanning directory for valid ROMs..."
