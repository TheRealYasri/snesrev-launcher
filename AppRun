#!/bin/bash

SCRIPT_PATH=`dirname $(realpath $0)`/usr
export LD_LIBRARY_PATH="${SCRIPT_PATH}/lib:${LD_LIBRARY_PATH}"
export LC_NUMERIC=en_US.UTF-8

HASH_Z3_US="6D4F10A8B10E10DBE624CB23CF03B88BB8252973"
HASH_SM="DA957F0D63D14CB441D215462904C4FA8519C613"
HASH_SMW="553CF42F35ACF63028A369608742BB5B913C103F|6B47BB75D16514B6A476AA0C73A683A2A4C18765"
HASH_SMAS="C05817C5B7DF2FBFE631563E0B37237156A8F6B6"
HASH_SMB1="4A5278150F3395419D68CB02A42F7C3C62CDF8B4"
HASH_SMBLL="493E14812AF7A92D0EACF00BA8BB6D3A266302CA"

HASH_Z3_DE="2E62494967FB0AFDF5DA1635607F9641DF7C6559"
HASH_Z3_FR="229364A1B92A05167CD38609B1AA98F7041987CC"
HASH_Z3_FRC="C1C6C7F76FFF936C534FF11F87A54162FC0AA100"
HASH_Z3_ES="461FCBD700D1332009C0E85A7A136E2A8E4B111E"
HASH_Z3_PL="3C4D605EEFDA1D76F101965138F238476655B11D"
HASH_Z3_PT="D0D09ED41F9C373FE6AFDCCAFBF0DA8C88D3D90D"
HASH_Z3_NL="FA8ADFDBA2697C9A54D583A1284A22AC764C7637"
HASH_Z3_SV="43CD3438469B2C3FE879EA2F410B3EF3CB3F1CA4"
HASH_Z3_REDUX="B2A07A59E64C498BC1B2F28728F9BF4014C8D582|9325C22EB0A2A1F0017157C8B620BC3A605CEDE1"

show_help() {
    echo "-------------------------------------------------------"
    echo " SNESREV Command Line Launcher"
    echo "-------------------------------------------------------"
    echo " Usage: $0 [command]"
    echo ""
    echo " Base Game Commands:"
    echo "  z3         Zelda 3 (US)      $HASH_Z3_US"
    echo "  sm         Super Metroid     $HASH_SM"
    echo "  smw        Super Mario World $HASH_SMW"
    echo "  smb1       Mario Bros 1      $HASH_SMB1"
    echo "  smbll      Lost Levels       $HASH_SMBLL"
    echo "  smas       (Extraction Src)  $HASH_SMAS"
    echo ""    
    echo " Zelda Commands (Requires US ROM + Lang ROM):"
    echo "  z3-de      (German)          $HASH_Z3_DE"
    echo "  z3-fr      (French)          $HASH_Z3_FR"
    echo "  z3-fr-c    (French Can.)     $HASH_Z3_FRC"
    echo "  z3-es      (Spanish)         $HASH_Z3_ES"
    echo "  z3-pl      (Polish)          $HASH_Z3_PL"
    echo "  z3-pt      (Portuguese)      $HASH_Z3_PT"
    echo "  z3-nl      (Dutch)           $HASH_Z3_NL"
    echo "  z3-sv      (Swedish)         $HASH_Z3_SV"
    echo "  z3-redux   (Redux)           $HASH_Z3_REDUX"
    echo ""
    echo "-------------------------------------------------------"
}

if [ $# -eq 0 ]; then show_help; exit 0; fi

find_and_rename_rom() {
    local TARGET_HASH="$1"
    local NEW_NAME="$2"
    local HASHER=""

    if command -v sha1sum &> /dev/null; then HASHER="sha1sum"
    elif command -v shasum &> /dev/null; then HASHER="shasum"
    else echo "Error: No hashing tool found." >&2; exit 1; fi

    local FOUND_FILE=$($HASHER *.s[mf]c *.smc 2>/dev/null | grep -iE "$TARGET_HASH" | head -n 1 | sed 's/^[0-9a-fA-F]*  //')

    if [ -n "$FOUND_FILE" ]; then
        if [ "$FOUND_FILE" != "$NEW_NAME" ]; then
            echo "Match found! Renaming '$FOUND_FILE' to '$NEW_NAME'..." >&2
            mv "$FOUND_FILE" "$NEW_NAME"
        fi
        echo "$NEW_NAME"
    fi
}

export Z3_ROM=$(find_and_rename_rom "$HASH_Z3_US" "zelda3.sfc")
export SM_ROM=$(find_and_rename_rom "$HASH_SM" "sm.smc")
export SMW_ROM=$(find_and_rename_rom "$HASH_SMW" "smw.sfc")
export SMAS_ROM=$(find_and_rename_rom "$HASH_SMAS" "smas.sfc")
export SMB1_ROM=$(find_and_rename_rom "$HASH_SMB1" "smb1.sfc")
export SMBLL_ROM=$(find_and_rename_rom "$HASH_SMBLL" "smbll.sfc")

export Z3_DE_ROM=$(find_and_rename_rom "$HASH_Z3_DE" "zelda3.de.sfc")
export Z3_FR_ROM=$(find_and_rename_rom "$HASH_Z3_FR" "zelda3.fr.sfc")
export Z3_FRC_ROM=$(find_and_rename_rom "$HASH_Z3_FRC" "zelda3.fr-c.sfc")
export Z3_ES_ROM=$(find_and_rename_rom "$HASH_Z3_ES" "zelda3.es.sfc")
export Z3_PL_ROM=$(find_and_rename_rom "$HASH_Z3_PL" "zelda3.pl.sfc")
export Z3_PT_ROM=$(find_and_rename_rom "$HASH_Z3_PT" "zelda3.pt.sfc")
export Z3_NL_ROM=$(find_and_rename_rom "$HASH_Z3_NL" "zelda3.nl.sfc")
export Z3_SV_ROM=$(find_and_rename_rom "$HASH_Z3_SV" "zelda3.sv.sfc")
export Z3_REDUX_ROM=$(find_and_rename_rom "$HASH_Z3_REDUX" "zelda3.redux.sfc")

extract_language () {
    sed -i 's/# Language/Language/g' ../zelda3.ini
    sed -i "s/Language = .*/Language = $1/g" ../zelda3.ini
    "${SCRIPT_PATH}"/bin/python3 restool.py --extract-dialogue -r translate.sfc
    "${SCRIPT_PATH}"/bin/python3 restool.py --languages="$1"
}

extractrom () {
    local TYPE=$1; shift
    case "$TYPE" in
        z3|z3-*)
            local TARGET_LANG=""
            local TRANS_ROM_VAR=""
            case "$TYPE" in
                z3|z3-en) TARGET_LANG="en";;
                z3-de)    TARGET_LANG="de";    TRANS_ROM_VAR="$Z3_DE_ROM";;
                z3-fr)    TARGET_LANG="fr";    TRANS_ROM_VAR="$Z3_FR_ROM";;
                z3-fr-c)  TARGET_LANG="fr-c";  TRANS_ROM_VAR="$Z3_FRC_ROM";;
                z3-es)    TARGET_LANG="es";    TRANS_ROM_VAR="$Z3_ES_ROM";;
                z3-pl)    TARGET_LANG="pl";    TRANS_ROM_VAR="$Z3_PL_ROM";;
                z3-pt)    TARGET_LANG="pt";    TRANS_ROM_VAR="$Z3_PT_ROM";;
                z3-nl)    TARGET_LANG="nl";    TRANS_ROM_VAR="$Z3_NL_ROM";;
                z3-sv)    TARGET_LANG="sv";    TRANS_ROM_VAR="$Z3_SV_ROM";;
                z3-redux) TARGET_LANG="redux"; TRANS_ROM_VAR="$Z3_REDUX_ROM";;
            esac

            local LANG_DAT="zelda3_assets.dat.$TARGET_LANG"

            if [ ! -e "$LANG_DAT" ]; then
                [ -z "$Z3_ROM" ] && { echo "Error: Missing US Zelda 3 ROM content."; exit 1; }
                if [ "$TARGET_LANG" != "en" ] && [ -z "$TRANS_ROM_VAR" ]; then
                    echo "Error: Missing translation ROM content for $TARGET_LANG."; exit 1
                fi

                export ASSETDIR="$(mktemp -d /tmp/z3-XXXXX)"
                cp -r "${SCRIPT_PATH}"/assets/* "$ASSETDIR"
                cp "$Z3_ROM" "$ASSETDIR/tables/zelda3.sfc"
                [ -n "$TRANS_ROM_VAR" ] && cp "$TRANS_ROM_VAR" "$ASSETDIR/tables/translate.sfc"
                
                cd "$ASSETDIR"/tables
                "${SCRIPT_PATH}"/bin/python3 restool.py --extract-from-rom -r zelda3.sfc
                [ -e "translate.sfc" ] && [ "$TARGET_LANG" != "en" ] && extract_language "$TARGET_LANG"
                cd - > /dev/null
                cp "$ASSETDIR"/tables/zelda3_assets.dat "$LANG_DAT"
                [ -e "$ASSETDIR"/zelda3.ini ] && cp "$ASSETDIR"/zelda3.ini "zelda3.ini.$TARGET_LANG"
                rm -rf "$ASSETDIR"
            fi

            cp "$LANG_DAT" zelda3_assets.dat
            [ -e "zelda3.ini.$TARGET_LANG" ] && cp "zelda3.ini.$TARGET_LANG" zelda3.ini
            [ ! -e zelda3.ini ] && cp "${SCRIPT_PATH}"/assets/zelda3.ini .
            "${SCRIPT_PATH}"/bin/zelda3 "$@"
            ;;
        sm)
            [ -z "$SM_ROM" ] && { echo "Error: Super Metroid ROM not found."; exit 1; }
            [ ! -e sm.ini ] && cp "${SCRIPT_PATH}"/assets/sm.ini .
            "${SCRIPT_PATH}"/bin/sm "$@"
            ;;
        smw)
            [ -z "$SMW_ROM" ] && { echo "Error: Super Mario World ROM not found."; exit 1; }
            [ ! -e smw.ini ] && cp "${SCRIPT_PATH}"/assets/smw.ini .
            "${SCRIPT_PATH}"/bin/smw "$@"
            ;;
        smb1|smbll)
            local TARGET_ROM=""
            [ "$TYPE" == "smb1" ] && TARGET_ROM="$SMB1_ROM" || TARGET_ROM="$SMBLL_ROM"
            if [ -z "$TARGET_ROM" ]; then
                 if [ ! -e "$TYPE.sfc" ]; then
                    [ -z "$SMAS_ROM" ] && { echo "Error: All-Stars ROM not found."; exit 1; }
                    export ASSETDIR="$(mktemp -d /tmp/smb-XXXXX)"
                    cp -r "${SCRIPT_PATH}"/assets/smb "$ASSETDIR"
                    cp "$SMAS_ROM" "$ASSETDIR/smas.sfc"
                    cd "$ASSETDIR"/smb && "${SCRIPT_PATH}"/bin/python3 extract.py && cd - > /dev/null
                    cp "$ASSETDIR/smb/smb1.sfc" . ; cp "$ASSETDIR/smb/smbll.sfc" .
                    rm -rf "$ASSETDIR"
                 fi
                 TARGET_ROM="$TYPE.sfc"
            fi
            [ ! -e smw.ini ] && cp "${SCRIPT_PATH}"/assets/smw.ini .
            "${SCRIPT_PATH}"/bin/smw "$TARGET_ROM" "$@"
            ;;
    esac
}

COMMAND=$1; shift
case "$COMMAND" in
    z3|z3-*|sm|smw|smb1|smbll) extractrom "$COMMAND" "$@" ;;
    *) echo "Error: '$COMMAND' invalid."; echo ""; show_help; exit 1 ;;
esac
